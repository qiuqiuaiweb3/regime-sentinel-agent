GOOGLE_CLOUD_PROJECT=poly-market-analysis
GOOGLE_CLOUD_REGION=asia-northeast1
MONGODB_URI=
MONGODB_DB=regime_sentinel

HOST=0.0.0.0
PORT=8080

GEMINI_ENABLED=true
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_SUMMARY_INTERVAL_MINUTES=30
GEMINI_MAX_CALLS_PER_HOUR=4
GEMINI_EMERGENCY_EXPLAIN_ENABLED=false
MANUAL_EXPLAIN_COOLDOWN_SECONDS=300

SSE_MAX_CLIENTS=25
SSE_HEARTBEAT_SECONDS=30
